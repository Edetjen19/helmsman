# Devin × Superset Remediation Control Plane, copy to .env and fill in.
# .env is gitignored. Never commit real keys. Put REAL values in .env, not here.

# --- Devin v3 (current API; cog_ service-user key) ---
DEVIN_API_KEY=                 # from Settings > Service users (starts with cog_, shown once)
DEVIN_ORG_ID=org-...           # Settings > Service Users page
DEVIN_BASE_URL=https://api.devin.ai/v3

# --- GitHub (the fork) ---
GITHUB_TOKEN=                  # blank = use authed gh CLI, or paste `gh auth token`
GITHUB_REPO=Edetjen19/superset

# --- Control plane config ---
WEBHOOK_SECRET=                # random hex; HMAC for the GitHub webhook
MAX_ACU_LIMIT=10
GLOBAL_ACU_BUDGET=50
POLL_INTERVAL_SECONDS=2         # SIMULATE board advances one step per poll; 2s keeps it lively
SIMULATE=true

# --- Scanner / resync ---
SUPERSET_CLONE=../superset      # path to a read-only Apache Superset clone (live scanner only)
ENABLE_ISSUE_SYNC=false        # true = worker pulls open devin-remediate issues from the fork (GitHub reads, no ACU)
ISSUE_SYNC_INTERVAL_SECONDS=60
SCAN_SCHEDULE_SECONDS=0         # >0 = worker runs the scanner on a tick, opening labeled issues (needs clone mount + token; no ACU)
